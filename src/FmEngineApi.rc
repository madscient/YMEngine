// FmEngineApi.rc
// DLL に埋め込むバージョン情報。
// Visual Studio の「プロパティ→詳細」や Explorer の「詳細タブ」で確認できる。

#include <windows.h>

#define VER_MAJOR 2
#define VER_MINOR 0
#define VER_PATCH 0

VS_VERSION_INFO VERSIONINFO
    FILEVERSION    VER_MAJOR, VER_MINOR, VER_PATCH, 0
    PRODUCTVERSION VER_MAJOR, VER_MINOR, VER_PATCH, 0
    FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
    FILEFLAGS      0
    FILEOS         VOS_NT_WINDOWS32
    FILETYPE       VFT_DLL
    FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"   // Language: English (US), Unicode
        BEGIN
            VALUE "FileDescription",  "ymfm FM Sound Engine DLL"
            VALUE "FileVersion",      "2.0.0.0"
            VALUE "ProductName",      "YMFMEngine"
            VALUE "ProductVersion",   "2.0.0.0"
            VALUE "LegalCopyright",   "ymfm (C) Aaron Giles (BSD-3-Clause)"
            VALUE "InternalName",     "YMFMEngine"
            VALUE "OriginalFilename", "YMFMEngine.dll"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 0x04b0
    END
END
